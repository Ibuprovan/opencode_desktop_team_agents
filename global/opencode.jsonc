{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
  "instructions": [
    "AGENT_RULES.md",
    "RULES.md"
  ],
  "agent": {
    "pm": {
      "description": "产品经理，负责需求分析、用户场景设计、编写完备的 PRD",
      "mode": "subagent",
      "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
      "permission": {
        "edit": "allow",
        "bash": "ask",
        "task": "ask"
      },
      "options": {}
    },
    "backend-dev": {
      "description": "后端工程师，负责业务逻辑实现、核心算法与函数编写，严格遵循DBA表结构",
      "mode": "subagent",
      "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "task": "ask"
      },
      "options": {}
    },
    "report": {
      "description": "报告生成器，负责实验报告、项目总结、Markdown与学术格式文档整理",
      "mode": "subagent",
      "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
      "permission": {
        "edit": "allow",
        "bash": "ask",
        "task": "ask"
      },
      "options": {}
    },
    "pmo": {
      "description": "项目管理办公室，负责接收需求、评估复杂度、拆解任务、监控状态机死循环",
      "mode": "all",
      "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
      "permission": {
        "edit": "allow",
        "bash": "ask",
        "task": "allow",
        "todowrite": "allow"
      },
      "options": {}
    },
    "architect": {
      "description": "系统架构师，负责技术选型、微服务划分、高并发规划、全局接口规范、技术仲裁",
      "mode": "subagent",
      "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
      "permission": {
        "edit": "allow",
        "bash": "ask",
        "task": "ask"
      },
      "options": {}
    },
    "reviewer": {
      "description": "代码审查员，负责依据规范检查代码、审查架构合规性、提供重构建议",
      "mode": "subagent",
      "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "task": "ask"
      },
      "options": {}
    },
    "memory": {
      "description": "记忆管理器，负责维护项目长期记忆、动态切片注入上下文",
      "mode": "subagent",
      "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
      "permission": {
        "edit": "allow",
        "bash": "ask",
        "task": "ask"
      },
      "options": {}
    },
    "frontend-dev": {
      "description": "前端工程师，负责 Web 前端、页面 UI、状态管理与接口对接",
      "mode": "subagent",
      "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "task": "ask"
      },
      "options": {}
    },
    "devops": {
      "description": "交付工程师，负责 Dockerfile、CI/CD、部署配置",
      "mode": "subagent",
      "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "task": "ask"
      },
      "options": {}
    },
    "security": {
      "description": "合规安全官，负责 OWASP 风险评估、权限检查、阻断高危代码",
      "mode": "subagent",
      "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "task": "ask"
      },
      "options": {}
    },
    "cyber": {
      "description": "网安特化智能体，负责静态代码审计、漏洞 PoC 验证、渗透测试分析",
      "mode": "subagent",
      "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "task": "ask"
      },
      "options": {}
    },
    "research": {
      "description": "前沿调研员，负责 CVE 漏洞调研、论文分析、技术攻关报告",
      "mode": "subagent",
      "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
      "permission": {
        "edit": "allow",
        "bash": "ask",
        "task": "ask"
      },
      "options": {}
    },
    "dba": {
      "description": "数据库工程师，负责物理建模、性能与索引优化、安全与扩展规范",
      "mode": "subagent",
      "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
      "permission": {
        "edit": "allow",
        "bash": "ask",
        "task": "ask"
      },
      "options": {}
    },
    "qa-engineer": {
      "description": "测试工程师，负责断言矩阵设计、自动化测试编写、质量红线卡点",
      "mode": "subagent",
      "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "task": "ask"
      },
      "options": {}
    }
  },
  "command": {
    "workflow": {
      "template": "pmo",
      "description": "让 PMO 以真实 subagent 委派方式执行完整工作流",
      "agent": "pmo"
    },
    "debug-workflow": {
      "template": "pmo",
      "description": "让 PMO 为缺陷或报错启动调试工作流",
      "agent": "pmo"
    },
    "re-arch": {
      "template": "pmo",
      "description": "让 PMO 为架构调整启动重构与仲裁工作流",
      "agent": "pmo"
    }
  },
  "disabled_providers": [],
  "provider": {
    "aliyun": {
      "name": "aliyun",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://dashscope.aliyuncs.com/compatible-mode/v1"
      },
      "models": {
        "qwen3.7-max": {
          "name": "qwen3.7-max"
        },
        "qwen3.7-plus": {
          "name": "qwen3.7-plus"
        },
        "glm-5.1": {
          "name": "glm-5.1"
        },
        "MiniMax/MiniMax-M3": {
          "name": "MiniMax/MiniMax-M3"
        },
        "kimi/kimi-k2.6": {
          "name": "kimi/kimi-k2.6"
        }
      }
    },
    "aiapi": {
      "name": "AIAPI",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://aiapi.world/v1"
      },
      "models": {
        "gpt-5.5": {
          "name": "gpt-5.5"
        },
        "gpt-5.4": {
          "name": "gpt-5.4"
        },
        "gpt-5.3-codex": {
          "name": "gpt-5.3-codex"
        },
        "claude-opus-4-8": {
          "name": "claude-opus-4-8"
        },
        "claude-opus-4-7": {
          "name": "claude-opus-4-7"
        },
        "claude-sonnet-4-6": {
          "name": "claude-sonnet-4-6"
        },
        "claude-haiku-4-5-20251001": {
          "name": "claude-haiku-4-5-20251001"
        },
        "gemini-3.5-flash": {
          "name": "gemini-3.5-flash"
        },
        "gemini-3.1-pro-preview": {
          "name": "gemini-3.1-pro-preview"
        },
        "claude-opus-4-6": {
          "name": "claude-opus-4-6"
        },
        "claude-sonnet-4-5-20250929": {
          "name": "claude-sonnet-4-5-20250929"
        },
        "gpt-4o": {
          "name": "gpt-4o"
        }
      }
    },
    "agnes": {
      "name": "Agnes",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://apihub.agnes-ai.com/v1"
      },
      "models": {
        "agnes-2.0-flash": {
          "name": "agnes-2.0-flash"
        }
      }
    }
  }
}
