{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "model": "xiaomi-token-plan-cn/mimo-v2.5-pro",
  "instructions": ["AGENTS.md"],
  "command": {
    "workflow": {
      "template": "pmo",
      "description": "让 PMO 以真实 subagent 委派方式执行完整工作流",
      "agent": "pmo"
    },
    "debug-workflow": {
      "template": "pmo",
      "description": "让 PMO 为缺陷或报错启动调试工作流",
      "agent": "pmo"
    },
    "re-arch": {
      "template": "pmo",
      "description": "让 PMO 为架构调整启动重构与仲裁工作流",
      "agent": "pmo"
    }
  }
}
